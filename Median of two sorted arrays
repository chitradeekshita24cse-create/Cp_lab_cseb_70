#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
int a[100005], b[100005];
int merged[200010];
int main() {
    int n, m;
    scanf("%d %d", &n, &m);
    for (int i = 0; i < n; i++)
        scanf("%d", &a[i]);
    for (int i = 0; i < m; i++)
        scanf("%d", &b[i]);
    int i = 0, j = 0, k = 0;
    while (i < n && j < m) {
        if (a[i] <= b[j])
            merged[k++] = a[i++];
        else
            merged[k++] = b[j++];
    }
    while (i < n)
        merged[k++] = a[i++];
    while (j < m)
        merged[k++] = b[j++];
    int total = n + m;
    int mid = total / 2;
    double median;
    if (total % 2 == 1) {
        median = (double)merged[mid];
    } else {
        median = (double)(merged[mid - 1] + merged[mid]) / 2.0;
    }
    printf("%.1f\n", median);
    return 0;
}
