#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int maxAscendingSum(int arr[],int n){
  if(n==0)
  return 0;
int maxSum=arr[0];
int currentSum=arr[0];
for(int i=1;i<n;i++){
    if(arr[i]>arr[i-1]){
        currentSum=currentSum+arr[i];
    }
    else{
        if(currentSum>maxSum)
        maxSum=currentSum;
        currentSum=arr[i];
    }
}
if(currentSum>maxSum)
        maxSum=currentSum;
        return maxSum;
}
int main() { 
     int n;
    scanf("%d", &n);

    int arr[n];

    for (int i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    printf("%d",maxAscendingSum(arr, n));
    return 0;
}
